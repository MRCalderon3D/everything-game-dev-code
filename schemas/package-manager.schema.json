{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.com/schemas/package-manager.schema.json",
  "title": "Harness Package Mapping",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "name",
    "adapter",
    "mapping"
  ],
  "properties": {
    "$schema": {
      "type": "string"
    },
    "name": {
      "type": "string",
      "minLength": 1
    },
    "adapter": {
      "type": "string",
      "minLength": 1
    },
    "mapping": {
      "type": "object",
      "minProperties": 1,
      "propertyNames": {
        "pattern": "^[a-z0-9][a-z0-9-]*$"
      },
      "additionalProperties": {
        "type": "string",
        "minLength": 1
      }
    },
    "engine_profiles": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string"
      },
      "uniqueItems": true
    }
  }
}
