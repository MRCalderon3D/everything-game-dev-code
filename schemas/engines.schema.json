{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "engines.schema.json",
  "title": "Engine layer registry",
  "type": "object",
  "required": ["version", "description", "engines"],
  "additionalProperties": false,
  "properties": {
    "$schema": { "type": "string" },
    "version": { "type": "integer", "minimum": 1 },
    "description": { "type": "string", "minLength": 1 },
    "engines": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["id", "display", "pathMarkers", "buildResolverAgent"],
        "additionalProperties": false,
        "properties": {
          "id": {
            "type": "string",
            "pattern": "^[a-z0-9]+(-[a-z0-9]+)*$",
            "description": "Kebab-case engine id; matches rules/<id>/, skills/<id>/, agents/<id>-*, commands/<id>-*."
          },
          "display": { "type": "string", "minLength": 1 },
          "pathMarkers": {
            "type": "array",
            "minItems": 1,
            "items": { "type": "string", "minLength": 1 },
            "description": "Lowercase substrings that identify project paths/content as belonging to this engine."
          },
          "buildResolverAgent": {
            "type": "boolean",
            "description": "Whether the engine layer ships a dedicated agents/<id>-build-resolver.md."
          }
        }
      }
    }
  }
}
