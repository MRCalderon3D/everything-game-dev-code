{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.com/schemas/mcp-servers.schema.json",
  "title": "MCP Server Registry",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "version",
    "servers",
    "profiles"
  ],
  "properties": {
    "$schema": {
      "type": "string"
    },
    "version": {
      "type": "integer",
      "minimum": 1
    },
    "description": {
      "type": "string"
    },
    "profiles": {
      "type": "object",
      "minProperties": 1,
      "propertyNames": {
        "pattern": "^[a-z0-9][a-z0-9-]*$"
      },
      "additionalProperties": {
        "type": "array",
        "minItems": 1,
        "items": {
          "type": "string"
        },
        "uniqueItems": true
      }
    },
    "servers": {
      "type": "object",
      "minProperties": 1,
      "propertyNames": {
        "pattern": "^[a-z0-9][a-z0-9-]*$"
      },
      "additionalProperties": {
        "type": "object",
        "additionalProperties": true,
        "required": [
          "purpose",
          "command"
        ],
        "properties": {
          "category": {
            "type": "string"
          },
          "enabled_by_default": {
            "type": "boolean"
          },
          "recommended": {
            "type": "boolean"
          },
          "purpose": {
            "type": "string",
            "minLength": 1
          },
          "when_to_use": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "transport": {
            "type": "string"
          },
          "command": {
            "type": "string",
            "minLength": 1
          },
          "args": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "env": {
            "type": "object"
          },
          "notes": {
            "type": "array",
            "items": {
              "type": "string"
            }
          }
        }
      }
    }
  }
}
