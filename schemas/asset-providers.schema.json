{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "asset-providers.schema.json",
  "title": "Generative asset provider registry",
  "type": "object",
  "required": ["version", "description", "defaultProvider", "providers"],
  "additionalProperties": false,
  "properties": {
    "$schema": { "type": "string" },
    "version": { "type": "integer", "minimum": 1 },
    "description": { "type": "string", "minLength": 1 },
    "defaultProvider": {
      "type": "string",
      "pattern": "^[a-z0-9]+(-[a-z0-9]+)*$",
      "description": "Provider id used when no provider is selected explicitly."
    },
    "providers": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["id", "display", "queueBaseUrl", "apiKeyEnv", "docsUrl", "capabilities"],
        "additionalProperties": false,
        "properties": {
          "id": {
            "type": "string",
            "pattern": "^[a-z0-9]+(-[a-z0-9]+)*$",
            "description": "Kebab-case provider id."
          },
          "display": { "type": "string", "minLength": 1 },
          "queueBaseUrl": {
            "type": "string",
            "pattern": "^https://",
            "description": "Base URL of the provider's async queue API; model ids are appended as path segments."
          },
          "apiKeyEnv": {
            "type": "string",
            "pattern": "^[A-Z][A-Z0-9_]*$",
            "description": "Environment variable holding the API key. Keys are never stored in the repository."
          },
          "docsUrl": { "type": "string", "pattern": "^https://" },
          "notes": {
            "type": "array",
            "items": { "type": "string", "minLength": 1 }
          },
          "capabilities": {
            "type": "object",
            "minProperties": 1,
            "additionalProperties": false,
            "patternProperties": {
              "^(image|skybox|model3d|sfx|music|speech|video)$": {
                "type": "object",
                "required": ["model", "promptField", "output"],
                "additionalProperties": false,
                "properties": {
                  "model": {
                    "type": "string",
                    "minLength": 1,
                    "description": "Default model id for this capability."
                  },
                  "alternatives": {
                    "type": "array",
                    "items": { "type": "string", "minLength": 1 },
                    "description": "Other model ids worth selecting via --model (e.g. higher fidelity or lower cost)."
                  },
                  "promptField": {
                    "type": "string",
                    "minLength": 1,
                    "description": "Name of the input field that carries the text prompt for the default model."
                  },
                  "defaults": {
                    "type": "object",
                    "description": "Extra input fields merged into every request for this capability (overridable via --input-json)."
                  },
                  "output": {
                    "type": "string",
                    "minLength": 1,
                    "description": "Expected output file format(s), informational."
                  },
                  "notes": { "type": "string", "minLength": 1 }
                }
              }
            }
          }
        }
      }
    }
  }
}
